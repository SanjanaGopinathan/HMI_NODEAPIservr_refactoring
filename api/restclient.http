	"tenant_id": "TENANT_01",
	"site_id": "SITE_01"
}

### Gateways - Get by ID
GET {{baseUrl}}/gateway/{{gatewayId}}

### Gateways - Update (fill fields to update)
PUT {{baseUrl}}/gateway/{{gatewayId}}
