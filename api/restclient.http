@baseUrl = http://localhost:8015
@assetId = 000000000000000000000000
@gatewayId = 000000000000000000000000
@modelId = 000000000000000000000000
@policyId = 000000000000000000000000
@profileId = 000000000000000000000000
@personnelId = 000000000000000000000000
@eventId = 000000000000000000000000
@actionId = 000000000000000000000000

### Assets - List
GET {{baseUrl}}/assets

### Assets - Create (fill required fields)
POST {{baseUrl}}/assets
Content-Type: application/json

{
	"tenant_id": "TENANT_01",
	"site_id": "SITE_01"
}

### Assets - Get by ID
GET {{baseUrl}}/assets/?tenant_id=TENANT_02&site_id=SITE_01

### Assets - Update (fill fields to update)
PUT {{baseUrl}}/assets/{{assetId}}
Content-Type: application/json

{
	"name": "Asset Name"
}

### Assets - Delete
DELETE {{baseUrl}}/assets/{{assetId}}

### Gateways - List
